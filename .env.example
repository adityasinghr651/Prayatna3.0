# ─── App ───────────────────────────────────────
APP_NAME=Urban Risk Intelligence Platform
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here

# ─── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/urbanrisk
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/urbanrisk

# ─── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── API Keys — Register at these links ────────
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# TomTom: https://developer.tomtom.com
TOMTOM_API_KEY=your_key_here

# PredictHQ: https://www.predicthq.com
PREDICTHQ_API_KEY=your_key_here

# Bluesky: https://bsky.app
BLUESKY_USERNAME=your_handle.bsky.social
BLUESKY_PASSWORD=your_password_here

# ─── Camera ────────────────────────────────────
PHONE_CAMERA_URL=http://192.168.x.x:8080/video

# ─── City Config ───────────────────────────────
DEFAULT_CITY=Indore
DEFAULT_LAT=22.7196
DEFAULT_LON=75.8577

# ─── Risk Thresholds ───────────────────────────
HIGH_RISK_THRESHOLD=0.7
MEDIUM_RISK_THRESHOLD=0.4

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL
NEXT_PUBLIC_WS_URL=http://localhost:8000